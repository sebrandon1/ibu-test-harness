# Hub cluster
HUB_API="https://api.example.com:6443"
HUB_USER="kubeadmin"
HUB_PASS=""

# Spoke (target for IBU)
SPOKE_NAME="cnfdf22"
SPOKE_NAMESPACE="cnfdf22"

# Seed cluster
SEED_NAME="cnfdf21"
SEED_NAMESPACE="cnfdf21"

# OCP versions
SOURCE_VERSION="4.20.2"
TARGET_VERSION="4.21.0-ec.2"

# Container images
REGISTRY="quay.io/bapalm"
LCA_IMAGE="${REGISTRY}/lifecycle-agent-operator:ibu-test"
RECERT_IMAGE="${REGISTRY}/recert:ibu-test"
SEED_IMAGE="${REGISTRY}/ibu-seed:${TARGET_VERSION}-test"
CATALOG_IMAGE="${REGISTRY}/lifecycle-agent-operator-catalog:ibu-test"
BUNDLE_IMAGE="${REGISTRY}/lifecycle-agent-operator-bundle:ibu-test"

# Build settings
PLATFORM="linux/amd64"
ENGINE="podman"

# Local repo paths (for image builds)
LCA_REPO_PATH=""
RECERT_REPO_PATH=""

# ClusterInstance manifest path
CLUSTER_INSTANCE_PATH=""

# Extra manifests ConfigMap source namespace (copied from seed cluster's namespace)
EXTRA_MANIFESTS_SOURCE_NS=""

# BMC credentials (for spoke reprovisioning)
BMC_USER="ADMIN"
BMC_PASS="ADMIN"

# Disk device for container storage partition
DISK_DEVICE="/dev/disk/by-path/pci-0000:05:00.0-nvme-1"

# Test configuration
NUM_RUNS=2
INSTALL_CERTMANAGER=true

# Container auth file for seed generation push
CONTAINER_AUTH_FILE="${HOME}/.config/containers/auth.json"
